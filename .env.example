AERORAMP_ENVIRONMENT=development
AERORAMP_DATABASE_URL=sqlite:///./aeroramp.db
AERORAMP_JWT_SECRET=replace-with-at-least-32-random-bytes
AERORAMP_ACCESS_TOKEN_MINUTES=30
AERORAMP_REFRESH_TOKEN_DAYS=7
AERORAMP_CORS_ORIGINS=http://localhost:3000
AERORAMP_TRUSTED_HOSTS=localhost,127.0.0.1,api
AERORAMP_UPLOAD_DIR=storage/uploads
AERORAMP_EVIDENCE_DIR=storage/evidence
AERORAMP_OBSERVATION_DIR=storage/observations
AERORAMP_MAX_UPLOAD_MB=1024
AERORAMP_DEFAULT_DETECTOR=motion
AERORAMP_INFERENCE_FPS=4
NEXT_PUBLIC_API_URL=http://localhost:8000
POSTGRES_DB=aeroramp
POSTGRES_USER=aeroramp
POSTGRES_PASSWORD=aeroramp
